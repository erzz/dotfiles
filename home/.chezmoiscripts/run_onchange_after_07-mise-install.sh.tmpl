#!/usr/bin/env bash
# Install mise-managed tools. Reads tool list from configs/mise/config.toml.
# Re-runs whenever ~/.config/mise/config.toml changes (its hash is below).
#
# mise config hash:
# {{ output "sha256sum" (joinPath .chezmoi.workingTree "configs" "mise" "config.toml") }}
{{- if not .ci }}
set -euo pipefail

# Ensure brew (and tools installed via brew like mise) are on PATH even if
# this is the first apply on a fresh machine where the user's shell config
# hasn't been sourced yet.
if [ -x /opt/homebrew/bin/brew ] && ! command -v brew >/dev/null 2>&1; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

if ! command -v mise >/dev/null 2>&1; then
  echo "==> mise not found (should have been installed by brew bundle); skipping"
  exit 0
fi

# Try to populate GH_TOKEN via fnox so private @ingka-group-digital npm
# packages can be installed in this same chezmoi-apply pass. fnox is
# installed via brew (see Brewfile), so it should be on PATH after script
# 03 ran. If 1Password CLI isn't unlocked, fnox will silently produce no
# output and we fall through to the "deferred install" path below.
if command -v fnox >/dev/null 2>&1 && [ -f "${HOME}/.config/fnox/config.toml" ]; then
  echo "==> Loading secrets via fnox..."
  # shellcheck disable=SC1090
  eval "$(fnox export -c "${HOME}/.config/fnox/config.toml" 2>/dev/null || true)"
fi

echo "==> Installing mise-managed tools (reads from ~/.config/mise/config.toml)..."
# `mise install` reads the active config and installs everything listed.
# Private @ingka packages will fail without GH_TOKEN; we let mise skip them
# and the user runs the printed command after authenticating fnox/1Password.
mise install --yes || {
  echo ""
  echo "==> Some mise tools failed to install (likely private @ingka packages)."
  echo "    Open a new shell (so fnox loads GH_TOKEN) and re-run:"
  echo "        mise install --yes"
  exit 0
}
{{- else }}
echo "==> CI mode — skipping mise install (requires auth for private packages)"
{{- end }}

