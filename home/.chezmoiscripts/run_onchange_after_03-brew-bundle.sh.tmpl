#!/usr/bin/env bash
# Run brew bundle for the main (non-MAS) Brewfile. The Brewfile contents are
# interpolated into a comment below so this script's hash changes whenever
# the Brewfile changes, triggering chezmoi to re-run it (run_onchange_).
#
# Mac App Store apps live in Brewfile.mas and are handled by script 04
# (which only runs interactively, since `mas` requires a tty for sudo).
#
# Brewfile hash:
{{- if .ci }}
# {{ output "sha256sum" (joinPath .chezmoi.workingTree "brew" "Brewfile.ci") }}
{{- else }}
# {{ output "sha256sum" (joinPath .chezmoi.workingTree "brew" "Brewfile") }}
{{- end }}
{{- if eq .chezmoi.os "darwin" }}
set -euo pipefail

# Ensure brew is on PATH even if this is the first apply on a fresh machine
# (parent shell pre-dates the brew install in script 02).
if [ -x /opt/homebrew/bin/brew ] && ! command -v brew >/dev/null 2>&1; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

DOTFILES="{{ .chezmoi.workingTree }}"

echo "==> Running brew bundle..."
{{ if .ci -}}
brew bundle --file "${DOTFILES}/brew/Brewfile.ci"
{{- else -}}
brew bundle --file "${DOTFILES}/brew/Brewfile"
{{- end }}
brew cleanup || true
{{- end }}
