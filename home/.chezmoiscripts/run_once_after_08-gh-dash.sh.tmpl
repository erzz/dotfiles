#!/usr/bin/env bash
# Install gh-dash extension (requires gh auth, skipped in CI).
{{- if not .ci }}
set -euo pipefail

# Ensure brew is on PATH (fresh-machine guard).
if [ -x /opt/homebrew/bin/brew ] && ! command -v brew >/dev/null 2>&1; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

if ! command -v gh >/dev/null 2>&1; then
  echo "==> gh not found (should have been installed by brew bundle); skipping gh-dash"
  exit 0
fi

# gh extension install requires authentication; skip cleanly if not signed in.
if ! gh auth status >/dev/null 2>&1; then
  echo "==> gh not authenticated; skipping gh-dash. Run 'gh auth login' then 'chezmoi apply'."
  exit 0
fi

if gh extension list 2>/dev/null | grep -q "dlvhdr/gh-dash"; then
  echo "==> gh-dash extension already installed"
else
  echo "==> Installing gh-dash extension..."
  gh extension install dlvhdr/gh-dash
fi
{{- end }}
