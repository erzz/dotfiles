#!/usr/bin/env bash
# Install gh-dash extension (requires gh auth, skipped in CI).
{{- if not .ci }}
set -euo pipefail

if ! command -v gh >/dev/null 2>&1; then
  echo "==> gh not found (should have been installed by brew bundle); skipping gh-dash"
  exit 0
fi

if gh extension list 2>/dev/null | grep -q "dlvhdr/gh-dash"; then
  echo "==> gh-dash extension already installed"
else
  echo "==> Installing gh-dash extension..."
  gh extension install dlvhdr/gh-dash
fi
{{- end }}
