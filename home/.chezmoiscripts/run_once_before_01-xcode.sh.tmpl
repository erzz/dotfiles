#!/usr/bin/env bash
# Install Xcode Command Line Tools (macOS only, interactive on first run).
# Skipped in CI — GitHub macOS runners ship with CLT.
{{- if and (eq .chezmoi.os "darwin") (not .ci) }}
set -euo pipefail

if xcode-select -p >/dev/null 2>&1; then
  echo "==> Xcode CLT already installed"
else
  echo "==> Installing Xcode Command Line Tools (this takes a while)..."
  echo "    A GUI installer will appear. This script will wait for it to finish."
  xcode-select --install || true
  # Poll instead of blocking on `read` so this works in non-tty contexts too.
  while ! xcode-select -p >/dev/null 2>&1; do
    sleep 10
  done
  echo "==> Xcode CLT installed"
fi
{{- end }}
