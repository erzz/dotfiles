{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "default_agent": "engineer",
  "instructions": ["~/.config/opencode/AGENTS.md"],
  "mcp": {
    "skapa": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "--",
        "skapa-design-system-mcp"
      ]
    },
    "workflows": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "--",
        "workflows-mcp"
      ]
    }
  }
}
