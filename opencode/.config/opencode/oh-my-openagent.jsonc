{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    // Main orchestrator: Claude Opus 4.6 max
    "sisyphus": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "max",
      "fallback_models": [
        { "model": "github-copilot/claude-sonnet-4.6" },
        { "model": "github-copilot/gpt-5.4", "variant": "medium" }
      ],
      "tools": {
        "skapa_*": false,
        "workflows_*": false,
        "context7_*": false,
        "grep_app_*": false,
        "session_*": false
      },
      "prompt_append": "You do NOT have access to Skapa design system or INGKA workflow MCP tools. You MUST delegate: (1) Any frontend, UI, styling, design, accessibility, or Skapa component work to the `frontend` custom agent or `visual-engineering` category - they have Skapa MCP access. (2) Any CI/CD, GitHub Actions, reusable workflows, or pipeline work to the `cicd` custom agent - it has the workflows MCP access. Never attempt to call skapa_* or workflows_* tools directly."
    },
    // Architecture consultation: GPT-5.4 high (upgraded from 5.2)
    "oracle": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        { "model": "github-copilot/gemini-2.5-pro", "variant": "high" },
        { "model": "github-copilot/claude-sonnet-4.6" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // Autonomous deep worker: GPT-5.4 medium (upgraded from 5.2-codex)
    "hephaestus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        { "model": "github-copilot/gpt-5.3-codex", "variant": "medium" },
        { "model": "github-copilot/gpt-5.2-codex", "variant": "medium" }
      ]
    },
    // Research agent: Claude Haiku 4.5 (speed over intelligence)
    "librarian": {
      "model": "github-copilot/claude-haiku-4.5",
      "fallback_models": [
        { "model": "github-copilot/gpt-5-mini" },
        { "model": "github-copilot/gpt-5.4-mini" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // Fast codebase grep: GPT-5-mini (0x multiplier, speed matters)
    "explore": {
      "model": "github-copilot/gpt-5-mini",
      "fallback_models": [
        { "model": "github-copilot/claude-haiku-4.5" },
        { "model": "github-copilot/gpt-5.4-mini" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // Vision & Screenshots: GPT-5.4 medium (gemini-3-flash not available)
    "multimodal-looker": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        { "model": "github-copilot/gpt-5.2", "variant": "medium" },
        { "model": "github-copilot/gemini-2.5-pro" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // Planning: Claude Opus 4.6 max
    "prometheus": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "max",
      "fallback_models": [
        { "model": "github-copilot/gpt-5.4", "variant": "high" },
        { "model": "github-copilot/gemini-2.5-pro", "variant": "high" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // Pre-planning analysis: Claude Opus 4.6 max
    "metis": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "max",
      "fallback_models": [
        { "model": "github-copilot/gpt-5.4", "variant": "high" },
        { "model": "github-copilot/claude-sonnet-4.6" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // Ruthless reviewer: GPT-5.4 xhigh (upgraded from 5.2 medium)
    "momus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        { "model": "github-copilot/gemini-2.5-pro", "variant": "high" },
        { "model": "github-copilot/claude-opus-4.6", "variant": "max" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // Todo orchestrator: Claude Sonnet 4.6 (upgraded from 4.5)
    "atlas": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        { "model": "github-copilot/claude-sonnet-4.5" },
        { "model": "github-copilot/gpt-5.4", "variant": "medium" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // Category task runner: Claude Sonnet 4.6 (new from installer)
    "sisyphus-junior": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        { "model": "github-copilot/claude-sonnet-4.5" },
        { "model": "github-copilot/gpt-5.4", "variant": "medium" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    }
  },
  "categories": {
    // Frontend, UI, CSS, design: Gemini 2.5 Pro (gemini-3.1-pro not available)
    "visual-engineering": {
      "model": "github-copilot/gemini-2.5-pro",
      "variant": "high",
      "fallback_models": [
        { "model": "github-copilot/claude-sonnet-4.6" },
        { "model": "github-copilot/gpt-5.4", "variant": "medium" }
      ],
      "tools": { "workflows_*": false },
      "prompt_append": "ALWAYS use Skapa components and design system via the MCP for all frontend, UI, styling and accessibility concerns rather than custom CSS or other frameworks such as tailwind."
    },
    // Maximum reasoning: GPT-5.4 xhigh (gemini-3-pro not available)
    "ultrabrain": {
      "model": "github-copilot/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        { "model": "github-copilot/gemini-2.5-pro", "variant": "high" },
        { "model": "github-copilot/claude-opus-4.6", "variant": "max" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // Autonomous deep work: GPT-5.4 medium (new from installer)
    "deep": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        { "model": "github-copilot/gemini-2.5-pro", "variant": "high" },
        { "model": "github-copilot/claude-sonnet-4.6" }
      ]
    },
    // Creative, novel approaches: Gemini 2.5 Pro (gemini-3-pro not available)
    "artistry": {
      "model": "github-copilot/gemini-2.5-pro",
      "variant": "high",
      "fallback_models": [
        { "model": "github-copilot/gpt-5.4" },
        { "model": "github-copilot/claude-sonnet-4.6" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // Simple, fast tasks: GPT-5.4-mini (upgraded from haiku)
    "quick": {
      "model": "github-copilot/gpt-5.4-mini",
      "fallback_models": [
        { "model": "github-copilot/claude-haiku-4.5" },
        { "model": "github-copilot/gpt-5-mini" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // General standard work: Claude Sonnet 4.6 (upgraded from 4.5)
    "unspecified-low": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        { "model": "github-copilot/claude-sonnet-4.5" },
        { "model": "github-copilot/gpt-5.4", "variant": "medium" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // General complex work: Claude Opus 4.6 max
    "unspecified-high": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "max",
      "fallback_models": [
        { "model": "github-copilot/claude-sonnet-4.6" },
        { "model": "github-copilot/gpt-5.4", "variant": "medium" }
      ]
    },
    // Text, docs, prose: Claude Sonnet 4.6 (upgraded from 4.5)
    "writing": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        { "model": "github-copilot/claude-sonnet-4.5" },
        { "model": "github-copilot/gpt-5.4", "variant": "medium" },
        { "model": "github-copilot/gpt-5.4-mini" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false }
    },
    // Git operations: small and simple
    "git": {
      "model": "github-copilot/gpt-5-mini",
      "fallback_models": [
        { "model": "github-copilot/gpt-5.4-mini" },
        { "model": "github-copilot/claude-haiku-4.5" }
      ],
      "tools": { "skapa_*": false, "workflows_*": false },
      "prompt_append": "ALWAYS use the conventional commits format for commit messages, and ensure that all commit messages are clear, concise, and descriptive of the changes made. ALWAYS ensure new branches are created from a fresh pull of the main branch"
    }
  },
  "skills": {
    "sources": [{ "path": "./skills", "recursive": true }]
  },
  "git_master": { "commit_footer": false, "include_co_authored_by": false }
}
