{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "plugin": ["@ramtinj95/opencode-tokenscope", "oh-my-opencode-slim"],
  "default_agent": "orchestrator",
  "instructions": ["~/.config/opencode/AGENTS.md"],
  "permission": {
    "skapa_*": "deny",
    "workflows_*": "deny"
  },
  "mcp": {
    "skapa": {
      "type": "local",
      "command": ["mise", "exec", "--", "skapa-design-system-mcp"]
    },
    "workflows": {
      "type": "local",
      "command": ["mise", "exec", "--", "workflows-mcp"]
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": true
}
