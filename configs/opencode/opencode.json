{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.6-terra",
  "plugin": [
    "@ramtinj95/opencode-tokenscope@1.7.1",
    "@tarquinen/opencode-dcp@3.1.14",
    "oh-my-opencode-slim@2.2.8"
  ],
  "default_agent": "orchestrator",
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],
  "permission": {
    "skapa_*": "deny",
    "workflows_*": "deny"
  },
  "mcp": {
    "skapa": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "--",
        "skapa-design-system-mcp"
      ]
    },
    "workflows": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "--",
        "workflows-mcp"
      ]
    }
  },
  "agent": {
    "cicd": {
      "permission": {
        "question": "deny",
        "skapa_*": "deny",
        "workflows_*": "allow"
      }
    },
    "designer": {
      "permission": {
        "skapa_*": "allow"
      }
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": true
}
