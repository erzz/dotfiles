{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "plugin": [
    "@ramtinj95/opencode-tokenscope",
    "oh-my-openagent@4.4.0"
  ],
  "default_agent": "sisyphus",
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],
  "permission": {
    "skapa_*": "deny",
    "workflows_*": "deny"
  },
  "mcp": {
    "skapa": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "--",
        "skapa-design-system-mcp"
      ]
    },
    "workflows": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "--",
        "workflows-mcp"
      ]
    }
  }
}
