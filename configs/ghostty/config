# theme="Atom"
unfocused-split-opacity        = 0.5
theme                          = dark:skapa-dark,light:skapa-dark

# Font
#font-family                    = Iosevka NF 
font-family                   = Fira Mono 
font-feature                   = calt
font-feature                   = dlig
font-feature                   = ss05

font-thicken                   = false
font-size                      = 18
#window-inherit-font-size       = true

# Look and Feel
adjust-cursor-thickness        = 3
adjust-underline-position      = 3
#background-opacity             = 0.9
bold-is-bright                 = true
cursor-style                   = block
cursor-style-blink             = true
cursor-click-to-move           = true
link-url                       = true
mouse-hide-while-typing        = true
window-vsync                   = true
window-height                  = 44
window-width                   = 168

# Other
macos-option-as-alt            = false
clipboard-paste-protection     = true
clipboard-trim-trailing-spaces = true
copy-on-select                 = true
macos-auto-secure-input        = true
macos-secure-input-indication  = true
quit-after-last-window-closed  = false
scrollback-limit               = 4200
shell-integration              = zsh

# Key bindings

# Pass ctrl+hjkl through to shell/tmux/nvim
keybind = ctrl+h=unbind
keybind = ctrl+j=unbind
keybind = ctrl+k=unbind
keybind = ctrl+l=unbind

# Pass alt+arrows through (word-jump in shell)
keybind = alt+arrow_left=unbind
keybind = alt+arrow_right=unbind

# Splits: super+hjkl focus, super+shift+hjkl create
keybind = super+h=goto_split:left
keybind = super+j=goto_split:down
keybind = super+k=goto_split:up
keybind = super+l=goto_split:right
keybind = super+shift+h=new_split:left
keybind = super+shift+j=new_split:down
keybind = super+shift+k=new_split:up
keybind = super+shift+l=new_split:right

# clear_screen (displaced from super+k)
keybind = super+ctrl+shift+k=clear_screen
